# ─────────────────────────────────────────────────────────────────────────────
# Kalshi Trading Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
# "demo" connects to demo-api.kalshi.co (safe, paper money)
# "production" connects to api.kalshi.co (real money — set explicitly)
KALSHI_ENV=demo

# ── Authentication ────────────────────────────────────────────────────────────
# Your Kalshi API key UUID (from kalshi.com/account/api-keys)
KALSHI_API_KEY_ID=your-api-key-uuid-here

# RSA private key: base64 of the key file. The file may be PEM (ASCII) or DER (binary);
# multiline base64 is fine inside double quotes. Alternatively paste the PEM in quotes.
# Windows (PowerShell), from the folder that contains your key.pem:
#   python -c "import base64, pathlib; print(base64.b64encode(pathlib.Path('key.pem').read_bytes()).decode())"
# macOS/Linux:
#   base64 -w 0 key.pem
KALSHI_PRIVATE_KEY_B64=base64encodedpemhere

# ── Markets to trade ──────────────────────────────────────────────────────────
# Comma-separated list of Kalshi market tickers to subscribe to.
# Find tickers using: python tools/screen.py --category Politics
KALSHI_TICKERS=PRES-2024-DEM,INXD-23DEC29-B4700

# ── Strategy ──────────────────────────────────────────────────────────────────
# kelly | green_up | arb | high_prob  (CLI --strategy overrides)
KALSHI_STRATEGY=kelly

# High-probability strategy
# KALSHI_HP_MIN_YES_ASK=85
# KALSHI_HP_MAX_YES_ASK=97
# KALSHI_HP_MIN_ROI_PCT=2.0
# KALSHI_HP_USE_FEE_ADJUSTED_ROI=true
# KALSHI_HP_ENTRY_MODE=limit_at_ask
# KALSHI_HP_POST_FILL=hold
# KALSHI_HP_STAKE_CENTS=5000

# Auto-discovery (alternative to KALSHI_TICKERS)
# KALSHI_DISCOVER=true
# KALSHI_DISCOVER_CATEGORY=Politics
# KALSHI_DISCOVER_TOP=10

# Kelly: model P(YES) per ticker — TICKER:PROB,TICKER2:PROB
# KALSHI_MODEL_PROB=PRES-2024-DEM:0.62

# Green-up (also overridable via CLI --entry-max, --hedge-trigger, etc.)
# KALSHI_GREEN_UP_ENTRY_MAX=25
# KALSHI_GREEN_UP_HEDGE_TRIGGER=68
# KALSHI_GREEN_UP_HEDGE_MODE=full_green
# KALSHI_GREEN_UP_STOP_LOSS=0.40

# Arbitrage: complementary pairs — TICKER_A:TICKER_B,TICKER_C:TICKER_D
# KALSHI_ARB_PAIRS=

# Live terminal table in main.py (seconds; 0 = off)
KALSHI_MONITOR_INTERVAL=15

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite blotter database file.
# Created automatically on first run.
KALSHI_DB_PATH=kalshi_bot.db

# Optional: PostgreSQL connection string (leave blank to use SQLite)
# KALSHI_POSTGRES_URL=postgresql://user:password@localhost:5432/kalshi

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR
KALSHI_LOG_LEVEL=INFO

# JSON Lines log file path (one JSON object per line)
KALSHI_LOG_FILE=kalshi_bot.jsonl
